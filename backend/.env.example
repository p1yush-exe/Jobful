# Copy to .env and fill in real values before running.

# ── Database ──────────────────────────────────────────────────────────────────
# Use the transaction pooler URL from Supabase (port 6543)
APP_DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=change-me-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACTIVE_KID=v1
JWT_ISSUER=jobful-api
JWT_AUDIENCE=jobful-client
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=7

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_BASE_URL=http://localhost:3000

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Leave blank to disable email sending (codes will appear in backend logs if AUTH_DEBUG_RETURN_CODES=true)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
EMAIL_VERIFICATION_CODE_MINUTES=10
EMAIL_VERIFICATION_MAX_ATTEMPTS=5
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60

# ── Debug ─────────────────────────────────────────────────────────────────────
# Set true in dev to have verification codes returned in API response
AUTH_DEBUG_RETURN_CODES=false

# ── AI / Groq ─────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# ── CV upload ─────────────────────────────────────────────────────────────────
CV_MAX_BYTES=5242880
CV_MIN_TEXT_CHARS=200

# ── Job search APIs ───────────────────────────────────────────────────────────
RAPIDAPI_KEY=                  # JSearch via RapidAPI
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
JOB_SEARCH_PAGES=2
JOB_SEARCH_DELAY=0.5

# ── HuggingFace (optional AI fallback) ───────────────────────────────────────
HF_TOKEN=

# ── Google SSO (disabled by default) ─────────────────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
